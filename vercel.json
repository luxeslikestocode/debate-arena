{
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "VITE_API_URL": "https://debate-signaling-server.onrender.com",
    "VITE_SIGNALING_URL": "wss://debate-signaling-server.onrender.com"
  }
}