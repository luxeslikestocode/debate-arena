# Debate Arena - Environment Variables

# Frontend URL (deployed on Vercel)
VITE_APP_URL="https://your-vercel-app.vercel.app"

# Signaling Server URL (deployed on Render/Railway)
VITE_API_URL="https://your-signaling-server.onrender.com"
VITE_SIGNALING_URL="wss://your-signaling-server.onrender.com"

